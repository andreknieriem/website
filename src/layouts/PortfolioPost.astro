---
import BaseLayout from './BaseLayout.astro';
const { frontmatter } = Astro.props;
---
<BaseLayout title={frontmatter.title}>
  <div class="portfolio-detail">
    <a class="backlink" href="/portfolio"><i class="icon-Back"></i> Zurück zur Übersicht</a>
    <br><br>
    <h1 class="align-center">{frontmatter.title}</h1>
    <div class="divider"><hr></div>
    
    <div class="row">
        <div class="col-md-4">
            <div class="info-container">
                <img src={frontmatter.image || "/fileadmin/Daten/Bilder/t3logo.png"} width="248" height="248" alt={frontmatter.title} class="img-fluid" />
                <div class="divider"><hr></div>
                {frontmatter.external_url && (
                    <a target="_blank" class="btn" href={frontmatter.external_url}>Seite besuchen</a>
                )}
            </div>
        </div>
        
        <div class="col-md-8">
            <h3>Beschreibung</h3>
            <div class="content">
                <slot />
            </div>
            
            {frontmatter.technologies && frontmatter.technologies.length > 0 && (
                <div class="mt-4">
                    <h3>Technologie(n)</h3>
                    {frontmatter.technologies.map(tech => (
                        <span class="tag">{tech}</span>
                    ))}
                </div>
            )}
        </div>
    </div>

    {frontmatter.gallery && frontmatter.gallery.length > 0 && (
        <>
            <div class="divider"><hr></div>
            <h2 class="align-center">Bilder</h2>
            <div data-aos="fade-up" class="portfolio-gallery">
                <div class="gallery-inner">
                    {frontmatter.gallery.map((item, index) => (
                        <div class={`row ${index === 0 ? 'active' : ''}`}>
                            <div class="col-md-8 image">
                                <a class="slb-image" href={item.image}>
                                    <img class="img-fluid" src={item.image} alt="" />
                                </a>
                            </div>
                            <div class="col-md-4">
                                <div class="image-text">
                                    <h3>Info</h3>
                                    <p>{item.info}</p>
                                </div>
                            </div>
                        </div>
                    ))}
                </div>
                <div class="col-md-8 navigation">
                    <a href="#" class="prev" data-dir="prev"><i class="icon-Back"></i></a>
                    <a href="#" class="next" data-dir="next"><i class="icon-Forward"></i></a>
                </div>
            </div>
        </>
    )}
  </div>
</BaseLayout>

<script>
  // Polyfill für 'global is not defined' Fehler
  if (typeof (window as any).global === 'undefined') {
    (window as any).global = window;
  }

  import SimpleLightbox from 'simplelightbox/dist/simple-lightbox.esm';
  
  const initLightbox = () => {
    const galleryLinks = document.querySelectorAll('.portfolio-gallery a.slb-image');
    if (galleryLinks.length > 0) {
        new SimpleLightbox('.portfolio-gallery a.slb-image', {});
    }
  };

  const initSlideshow = () => {
    const gallery = document.querySelector('.portfolio-gallery');
    if (!gallery) return;

    const navLinks = gallery.querySelectorAll('.navigation a');
    const rows = gallery.querySelectorAll('.gallery-inner > .row');

    if (rows.length <= 1) {
        const nav = gallery.querySelector('.navigation');
        if (nav) (nav as HTMLElement).style.display = 'none';
        return;
    }

    const showSlide = (dir) => {
      let current = gallery.querySelector('.row.active');
      if (!current) {
        current = rows[0];
        current.classList.add('active');
      }

      let next;
      if (dir === 'next') {
        next = current.nextElementSibling || rows[0];
      } else {
        next = current.previousElementSibling || rows[rows.length - 1];
      }

      current.classList.remove('active');
      (current as HTMLElement).style.display = 'none';
      
      next.classList.add('active');
      (next as HTMLElement).style.display = 'flex';
    };

    navLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const dir = (link as HTMLElement).dataset.dir;
        showSlide(dir);
      });
    });
  };

  document.addEventListener('astro:page-load', () => {
    initLightbox();
    initSlideshow();
  });
  
  // Initial load
  initLightbox();
  initSlideshow();
</script>
